# ============ SERVER CONFIG ============
PORT=5000
NODE_ENV=development

# ============ MONGODB ============
# Local example:  mongodb://127.0.0.1:27017/portfolio
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# ============ JWT / AUTH ============
# REQUIRED. The server refuses to start without this.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars_long
JWT_EXPIRES_IN=7d

# Default admin (created on first run / when running `npm run seed`)
# ADMIN_PASSWORD is REQUIRED in production — the seed script refuses to run
# without it when NODE_ENV=production.
ADMIN_NAME=Haroon
ADMIN_EMAIL=realmrhak@admin.com
ADMIN_PASSWORD=realmrhak1234@4321

# ============ CORS ============
# Comma-separated list of allowed browser origins.
# In production this MUST be set to your Vercel URL (e.g. https://realmrhak-portfolio.vercel.app).
# Server-to-server calls (no Origin header) are always allowed.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://realmrhak-portfolio.vercel.app

# ============ UPLOAD LIMITS ============
# Max upload size in MB. Hard-capped at 25.
MAX_UPLOAD_MB=5

# ============ CLOUDINARY (image storage) ============
# Required for production on Render — the free tier has an EPHEMERAL filesystem
# that wipes /uploads on every deploy. Cloudinary's free tier (25 GB storage,
# 25 GB monthly bandwidth) is more than enough for a portfolio.
# Get these from https://cloudinary.com/console after signup.
# If left blank, the backend falls back to local /uploads/ (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
